{
  "expo": {
    "name": "DLX",
    "slug": "dlx-satinalma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/dlxx.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "com.dlx",
    "splash": {
      "backgroundColor": "#01E884"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dlx",
      "buildNumber": "14",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "İade ve teslim süreçlerinde fotoğraf çekmek için kamera erişimi gerekir.",
        "NSPhotoLibraryUsageDescription": "Talep eklerken malzeme görsellerini seçebilmek için fotoğraf galerinize erişim gerekir.",
        "NSPhotoLibraryAddUsageDescription": "Çekilen fotoğrafları kaydetmek için galeri erişimi gerekir."
      }
    },
    "android": {
      "package": "com.dlx_satinalma",
      "versionCode": 14,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/dlxx.png",
        "backgroundColor": "#01E884"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/dl.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/dld.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#01E884"
        }
      ],
      "expo-router",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#ffffff",
          "barStyle": "dark"
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/dl.png",
          "color": "#2DD4BF",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Talep eklerken malzeme görsellerini seçebilmek için fotoğraf galerinize erişim gerekir.",
          "cameraPermission": "İade ve teslim süreçlerinde fotoğraf çekmek için kamera erişimi gerekir."
        }
      ],
      "expo-apple-authentication"
    ]
  }
}
